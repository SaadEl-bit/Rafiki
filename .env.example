# ==========================================
# RAFIKI: BACKEND ENVIRONMENT VARIABLES
# ==========================================

# Your Hugging Face Token (Must have Read access to your private model and datasets)
# Get yours here: https://huggingface.co/settings/tokens
HF_TOKEN="hf_your_token_here"

# The Hugging Face model repository ID for your fine-tuned model
HF_MODEL_ID="Saad-Elouakate/rafiki-qwen-2.5-finetune"

# Allowed origins for CORS. Comma-separated list.
# For local dev use http://localhost:3000. On production, add your Vercel domain.
ALLOWED_ORIGINS="http://localhost:3000"

# (Optional) Port for the FastAPI backend server to run on
# Railway sets this automatically in production
PORT=8000


# ==========================================
# RAFIKI: FRONTEND ENVIRONMENT VARIABLES
# ==========================================

# URL of the FastAPI backend.
# For local dev: http://localhost:8000
# For production: https://your-railway-app-url.up.railway.app
NEXT_PUBLIC_API_URL="http://localhost:8000"
